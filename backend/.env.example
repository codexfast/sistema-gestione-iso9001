# =========================================
# BACKEND API - Variabili di Ambiente
# =========================================

# Server
NODE_ENV=production
PORT=10443
API_BASE_PATH=/api/v1

# Database SQL Server
DB_SERVER=www.fr-busato.it
DB_PORT=11043
DB_DATABASE=SGQ_ISO9001
DB_USER=pascarella
DB_PASSWORD=#Gestione2025@
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# JWT Authentication
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_CHANGE_THIS_IN_PRODUCTION
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://systemgest.netlify.app,http://localhost:5173
CORS_CREDENTIALS=true

# File Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,audio/mpeg,audio/mp4,audio/wav,video/mp4,video/webm,application/pdf

# Rate Limiting
# RATE_LIMIT_DISABLED=true  # Solo sviluppo locale — NON impostare in produzione
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20

# OpenAI (opzionale) — analisi strutturata su Import PDF (licenza ai_import)
# OPENAI_API_KEY=sk-...
# OPENAI_IMPORT_MODEL=gpt-4o-mini
# OPENAI_IMPORT_MAX_CHARS=20000
# OPENAI_IMPORT_TIMEOUT_MS=90000
# OPENAI_IMPORT_RATE_LIMIT_MAX=24

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# SSL/TLS (se usi HTTPS direttamente in Node)
SSL_ENABLED=true
SSL_KEY_PATH=/etc/letsencrypt/live/www.fr-busato.it/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/www.fr-busato.it/fullchain.pem

# Backup automatico
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DIR=/var/backups/sgq-iso9001
BACKUP_RETENTION_DAYS=30
