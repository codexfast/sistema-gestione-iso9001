{
  "development": {
    "server": "YOUR_SQLSERVER_HOST",
    "port": 1433,
    "database": "SGQ_ISO9001",
    "user": "YOUR_SQL_USER",
    "password": "YOUR_SQL_PASSWORD",
    "options": {
      "encrypt": true,
      "trustServerCertificate": true,
      "enableArithAbort": true,
      "connectTimeout": 30000,
      "requestTimeout": 30000
    },
    "pool": {
      "max": 5,
      "min": 0,
      "idleTimeoutMillis": 30000
    }
  },
  "production": {
    "server": "YOUR_SQLSERVER_HOST",
    "port": 1433,
    "database": "SGQ_ISO9001",
    "user": "YOUR_SQL_USER",
    "password": "YOUR_SQL_PASSWORD",
    "options": {
      "encrypt": true,
      "trustServerCertificate": true,
      "enableArithAbort": true,
      "connectTimeout": 30000,
      "requestTimeout": 30000
    },
    "pool": {
      "max": 10,
      "min": 2,
      "idleTimeoutMillis": 30000
    }
  },
  "test": {
    "server": "localhost",
    "port": 1433,
    "database": "SGQ_ISO9001_Test",
    "user": "sgq_test_user",
    "password": "YOUR_TEST_SQL_PASSWORD",
    "options": {
      "encrypt": true,
      "trustServerCertificate": true,
      "enableArithAbort": true,
      "connectTimeout": 30000,
      "requestTimeout": 30000
    },
    "pool": {
      "max": 3,
      "min": 0,
      "idleTimeoutMillis": 30000
    }
  }
}
